{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reed",
  "version": "0.1.0",
  "identifier": "epub.reed",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reed",
        "width": 1180,
        "height": 780,
        "minWidth": 820,
        "minHeight": 560,
        "center": true,
        "dragDropEnabled": true,
        "backgroundColor": "#f7f5ec"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "fileAssociations": [
      {
        "ext": ["epub"],
        "name": "EPUB",
        "description": "Buku elektronik EPUB",
        "mimeType": "application/epub+zip",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
